# API Helpers

```{r api_helpers}
bls_fetch <- function(series_ids, start_year, end_year, bls_key = Sys.getenv("BLS_KEY")) {
  url <- "https://api.bls.gov/publicAPI/v2/timeseries/data/"
  body <- list(
    seriesid = series_ids,
    startyear = as.character(start_year),
    endyear   = as.character(end_year)
  )
  if (nzchar(bls_key)) body$registrationkey <- bls_key

  resp <- request(url) |>
    req_method("POST") |>
    req_body_json(body) |>
    req_perform()

  dat <- jsonlite::fromJSON(resp_body_string(resp), simplifyVector = TRUE)

  # Fail loudly if BLS rejected the request
  if (!is.null(dat$status) && dat$status != "REQUEST_SUCCEEDED") {
    msg <- paste(c(dat$message, dat$Results$errors), collapse = " | ")
    stop("BLS API request failed: ", msg, call. = FALSE)
  }

  series <- dat$Results$series

  # Normalize to a list of series objects: each has $seriesID and $data
  series_list <- NULL

  if (is.data.frame(series)) {
    # Common when fromJSON simplifies; 'data' becomes a list-column
    series_list <- lapply(seq_len(nrow(series)), function(i) {
      list(seriesID = series$seriesID[i], data = series$data[[i]])
    })
  } else if (is.list(series)) {
    # Already list-of-series
    series_list <- series
  } else {
    stop("Unexpected BLS payload: Results$series is neither data.frame nor list.", call. = FALSE)
  }

  out <- lapply(series_list, function(s) {
    d <- s$data
    tibble::tibble(
      series_id = s$seriesID,
      year      = as.integer(d$year),
      period    = d$period,
      value     = as.numeric(d$value)
    )
  }) |>
    dplyr::bind_rows()

  out |>
    dplyr::filter(stringr::str_detect(period, "^M\\d\\d$")) |>
    dplyr::mutate(
      month = as.integer(stringr::str_remove(period, "M")),
      date  = as.Date(sprintf("%04d-%02d-01", year, month))
    ) |>
    dplyr::select(series_id, date, value) |>
    dplyr::arrange(series_id, date)
}


fred_fetch <- function(series_id, start_date, end_date, fred_key = Sys.getenv("FRED_KEY")) {
  if (nzchar(fred_key)) {
    url <- "https://api.stlouisfed.org/fred/series/observations"

    resp <- request(url) |>
      req_url_query(
        series_id = series_id,
        api_key = fred_key,
        file_type = "json",
        observation_start = as.character(start_date),
        observation_end   = as.character(end_date),
        frequency = "m"
      ) |>
      req_perform()

    dat <- fromJSON(resp_body_string(resp))
    return(
      tibble(
        series_id = series_id,
        date = as.Date(dat$observations$date),
        value = as.numeric(na_if(dat$observations$value, "."))
      ) |>
        arrange(date)
    )
  }

  # Fallback endpoint if FRED_KEY is not set.
  csv_url <- sprintf(
    "https://fred.stlouisfed.org/graph/fredgraph.csv?id=%s&cosd=%s&coed=%s",
    series_id, as.character(start_date), as.character(end_date)
  )

  read.csv(csv_url) |>
    tibble::as_tibble() |>
    rename(date = DATE, value = !!series_id) |>
    mutate(
      series_id = series_id,
      date = as.Date(date),
      value = as.numeric(value)
    ) |>
    select(series_id, date, value) |>
    arrange(date)
}
```

