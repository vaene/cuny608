# Period deep-dives 

For each period of interest, we reproduce **two dual-axis line charts**:

1) **Fed Funds vs Unemployment** (dashed = unemployment, right axis)  
2) **Fed Funds vs Inflation (CPI YoY)** (dashed = inflation, right axis)

Each chart **rescales the right axis per-period** so the two lines are visually comparable and the relationship is clear.

```{r 30_dual_axis_helpers, message=FALSE, warning=FALSE}
# Dual-axis helper: plot Fed Funds on left axis, rescaled series on right axis
dual_axis_plot <- function(d, y2, title, y1_limits = NULL, y2_range_override = NULL) {
  # y2: one of c("unemp","infl_yoy")
  d <- d |>
    dplyr::select(date, ffr, !!rlang::sym(y2)) |>
    dplyr::filter(!is.na(ffr), !is.na(.data[[y2]]))

  # Map to Theory chart naming + color scheme keys
  y2_label <- dplyr::case_when(
    y2 == "unemp" ~ "Unemployment",
    y2 == "infl_yoy" ~ "Inflation",
    TRUE ~ y2
  )

  right_key <- dplyr::case_when(
    y2 == "unemp" ~ "unemployment_rate",
    y2 == "infl_yoy" ~ "inflation_rate",
    TRUE ~ "inflation_rate"
  )

  # Targets (for context against the mandate)
  infl_target <- 2.0      # 2% long-run inflation target
  unemp_target <- 4.5     # simple benchmark (varies over time)
  infl_moe <- 0.5         # +/- 0.5 pp visual margin of error
  unemp_moe <- 0.5        # +/- 0.5 pp visual margin of error

  # Per-period scaling so the relationship is visible (ranges differ by period)
  rng1 <- range(d$ffr, na.rm = TRUE)
  rng2 <- if (!is.null(y2_range_override)) y2_range_override else range(d[[y2]], na.rm = TRUE)

  if (diff(rng2) == 0) {
    scale <- 1
    shift <- 0
  } else {
    scale <- diff(rng1) / diff(rng2)
    shift <- rng1[1] - rng2[1] * scale
  }

  d <- d |> dplyr::mutate(y2_scaled = .data[[y2]] * scale + shift)

  # Convert targets onto the left axis so they plot correctly with the dual-axis transform
  y2_target <- if (y2 == "infl_yoy") infl_target else if (y2 == "unemp") unemp_target else NA_real_
  y2_target_scaled <- y2_target * scale + shift
  y2_moe <- if (y2 == "infl_yoy") infl_moe else if (y2 == "unemp") unemp_moe else NA_real_
  y2_moe_scaled <- y2_moe * scale

  p <- ggplot(d, aes(x = date)) +
    {if (!is.na(y2_target_scaled) && !is.na(y2_moe_scaled)) geom_rect(
        xmin = -Inf, xmax = Inf,
        ymin = y2_target_scaled - y2_moe_scaled,
        ymax = y2_target_scaled + y2_moe_scaled,
        fill = if (y2 == "infl_yoy") "#F4A3A3" else "#9DC7F5",
        alpha = 0.25,
        inherit.aes = FALSE
      )} +
    geom_line(aes(y = ffr, color = "Interest Rate"), linewidth = 1) +
    geom_line(aes(y = y2_scaled, color = y2_label), linewidth = 1) +
    {if (!is.na(y2_target_scaled)) geom_hline(
        yintercept = y2_target_scaled,
        linewidth = 0.9,
        linetype = "dashed",
        color = unname(series_colors[right_key])
      )} +
    scale_color_manual(
      values = c(
        "Interest Rate" = unname(series_colors["interest_rate"]),
        "Inflation"     = unname(series_colors["inflation_rate"]),
        "Unemployment"  = unname(series_colors["unemployment_rate"])
      )
    ) +
    scale_y_continuous(
      name = "Interest Rate (%)",
      labels = label_number(accuracy = 0.1),
      sec.axis = sec_axis(
        ~ (. - shift) / scale,
        name = paste0(y2_label, ifelse(y2 == "unemp", " (%)", " (CPI YoY %)")),
        labels = label_number(accuracy = 0.1)
      )
    ) +
    labs(title = title, x = NULL, color = NULL) +
    low_ink_theme +
    theme(legend.position = "bottom")

  if (!is.null(y1_limits)) {
    p <- p + coord_cartesian(ylim = y1_limits)
  }

  apply_theory_axes(p, right_key)
}

