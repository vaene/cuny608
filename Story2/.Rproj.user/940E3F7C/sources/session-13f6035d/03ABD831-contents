# Pull and Prepare Data (Last 25 Years)

```{r fetch_data}
end_date <- analysis_end_date
start_date <- analysis_start_date

start_year <- year(start_date)
end_year   <- year(end_date)

# CSV cache paths
dir.create("data", showWarnings = FALSE)
df_cache_path <- file.path("data", "story2_final_data.csv")
bls_cache_path <- file.path("data", "story2_bls_raw.csv")
ffr_cache_path <- file.path("data", "story2_fedfunds_raw.csv")
cpi_cache_path <- file.path("data", "story2_cpi_fred_raw.csv")
unemp_cache_path <- file.path("data", "story2_unrate_fred_raw.csv")

# Reuse cached final data if available; otherwise download and cache all raw pulls
if (file.exists(df_cache_path)) {
  message("Loading cached data from ", df_cache_path)
  df <- readr::read_csv(df_cache_path, show_col_types = FALSE) |>
    mutate(date = as.Date(date))
} else {
  # --- Primary source requested by assignment: BLS for CPI + Unemployment ---
  bls <- bls_fetch(
    series_ids = c("CUSR0000SA0", "LNS14000000"),
    start_year = start_year,
    end_year   = end_year
  )
  readr::write_csv(bls, bls_cache_path)

  # FRED: Fed Funds (always needed)
  ffr <- fred_fetch("FEDFUNDS", start_date, end_date)
  readr::write_csv(ffr, ffr_cache_path)

  # If BLS returns a shorter window, fall back to FRED-hosted BLS series.
  bls_max_date <- suppressWarnings(max(bls$date, na.rm = TRUE))

  if (is.finite(bls_max_date) && bls_max_date < as.Date("2023-12-01")) {
    message("BLS returned data only through ", bls_max_date,
            ". Falling back to FRED for CPI & unemployment to complete the window.")

    cpi_fred <- fred_fetch("CPIAUCSL", start_date, end_date) |> rename(cpi = value)
    un_fred  <- fred_fetch("UNRATE",   start_date, end_date) |> rename(unemp = value)

    readr::write_csv(cpi_fred, cpi_cache_path)
    readr::write_csv(un_fred, unemp_cache_path)

    df <- cpi_fred |>
      full_join(un_fred, by = "date") |>
      full_join(ffr |> rename(ffr = value), by = "date") |>
      arrange(date)
  } else {
    df <- bls |>
      pivot_wider(names_from = series_id, values_from = value) |>
      rename(cpi = CUSR0000SA0, unemp = LNS14000000) |>
      full_join(ffr |> rename(ffr = value), by = "date") |>
      arrange(date)
  }
}

