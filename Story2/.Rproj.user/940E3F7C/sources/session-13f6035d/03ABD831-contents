# Period helper: 100% stacked bars for Employment / Inflation / Both
period_stacked_pct_plot <- function(data, start_date, end_date, period_label) {
  d <- data |>
    dplyr::filter(date >= start_date, date <= end_date, !is.na(infl_yoy), !is.na(unemp)) |>
    dplyr::mutate(
      emp_ok = unemp <= 5,
      infl_ok = infl_yoy >= 1 & infl_yoy <= 3,
      both_ok = emp_ok & infl_ok
    )

  bar_df <- tibble::tibble(
    metric = c("Employment", "Inflation", "Both"),
    ok = c(mean(d$emp_ok), mean(d$infl_ok), mean(d$both_ok))
  ) |>
    dplyr::mutate(not_ok = 1 - ok) |>
    tidyr::pivot_longer(c(ok, not_ok), names_to = "status", values_to = "share") |>
    dplyr::mutate(
      status = dplyr::if_else(status == "ok", "OK", "Not OK"),
      metric = factor(metric, levels = c("Employment", "Inflation", "Both"))
    )

  ggplot(bar_df, aes(x = metric, y = share, fill = status)) +
    geom_col(width = 0.65) +
    geom_text(
      aes(label = scales::percent(share, accuracy = 0.1)),
      position = position_stack(vjust = 0.5),
      size = 3.6
    ) +
    scale_fill_manual(values = c("OK" = "#BFE7BF", "Not OK" = "#F6B3B3")) +
    scale_y_continuous(
      labels = scales::percent_format(accuracy = 1),
      limits = c(0, 1),
      expand = expansion(mult = c(0, 0.02))
    ) +
    labs(
      title = paste0(period_label, ": Percentage of months meeting benchmarks"),
      x = NULL,
      y = "Share of months",
      fill = NULL
    ) +
    low_ink_theme +
    theme(legend.position = "bottom")
}
